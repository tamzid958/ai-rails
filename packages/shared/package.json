{
  "name": "@airails/shared",
  "version": "0.1.1-alpha.1",
  "license": "BUSL-1.1",
  "description": "Shared utilities for the AIRails platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tamzid958/ai-rails.git",
    "directory": "packages/shared"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "prisma generate --schema ../../prisma/schema.prisma && tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run src/__tests__ --exclude src/__tests__/product-context.test.ts",
    "test:integration": "vitest run src/__tests__/product-context.test.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "pg": "^8.20.0",
    "zod": "3.24.2"
  }
}
