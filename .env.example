# Database
DATABASE_URL=postgresql://airails:changeme@postgres:5432/airails

# Redis
REDIS_URL=redis://redis:6379

# Gateway
AIRAILS_SECRET=change-this-to-a-random-secret
AIRAILS_PORT=8080
LITELLM_URL=http://litellm:4000

# LiteLLM
LITELLM_MASTER_KEY=change-this
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Dashboard
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — GitLab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Microsoft (Entra ID / Azure AD)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# NextAuth
AUTH_SECRET=change-this-to-a-random-secret
AUTH_TRUST_HOST=true

# Access Control
# Comma-separated list of allowed email domains (empty = allow all)
ALLOWED_EMAIL_DOMAINS=
# Set to "true" to require users be pre-added to a product before they can access
INVITE_ONLY=false
# Who can create products: "anyone" | "owners" (default: anyone)
PRODUCT_CREATION=anyone

# Webhook
AIRAILS_WEBHOOK_SECRET=change-this
WEBHOOK_PORT=8081

# Production
CORS_ORIGIN=https://your-domain.com

# Logging
LOG_LEVEL=info
LOG_PROMPTS=true
LOG_RESPONSES=false
